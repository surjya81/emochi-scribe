{
  "manifest_version": 3,
  "name": "Emochi Scribe",
  "version": "3.1.0",
  "description": "Download your Emochi chat conversations.",
  "permissions":["activeTab", "scripting", "downloads"],
  "host_permissions":[
    "https://emochi.com/*",
    "https://*.emochi.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches":["https://emochi.com/*", "https://*.emochi.com/*"],
      "js":["interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches":["https://emochi.com/*", "https://*.emochi.com/*"],
      "js": ["content.js"],
      "css":["content.css"],
      "run_at": "document_idle"
    }
  ]
}